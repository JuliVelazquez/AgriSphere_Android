<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configuración de TI / RH"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Parámetros de Geocerca del Invernadero"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etNombreEmpresa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre (Ej. Invernadero Marquesado)"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etLatitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Latitud (Ej. 21.5041)"
        android:inputType="numberDecimal|numberSigned"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etLongitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Longitud (Ej. -104.8945)"
        android:inputType="numberDecimal|numberSigned"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etRadio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Radio de tolerancia (Metros)"
        android:inputType="number"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnGuardarConfig"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Guardar Parámetros"
        android:textSize="16sp"
        android:backgroundTint="#2E7D32"/> </LinearLayout>